{
  "name": "freeride-korea-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "vinext build",
    "build:next": "next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .vinext --ignore-pattern .wrangler",
    "qa:links": "node ./scripts/qa-internal-links.mjs",
    "qa:runtime": "node ./scripts/qa-runtime.mjs",
    "qa:seo": "node ./scripts/qa-seo.mjs",
    "qa:membership": "node ./scripts/qa-membership-registration.mjs",
    "qa:member-update": "node ./scripts/qa-member-update.mjs",
    "qa:deploy-env": "node ./scripts/qa-deploy-env.mjs",
    "qa:smoke": "node ./scripts/qa-smoke.mjs",
    "qa:release": "npm run lint && npm run qa:links && npm run qa:seo && npm run qa:runtime",
    "qa:preflight": "node ./scripts/qa-preflight.mjs",
    "db:seed:generate": "node ./scripts/generate-supabase-seed.mjs",
    "db:check": "node ./scripts/check-supabase.mjs",
    "db:storage:ensure": "node ./scripts/check-supabase.mjs --ensure-storage"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.5",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wait-on": "^9.0.10",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
